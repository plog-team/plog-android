<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.plog.ui.home.HomeFragment"
        android:label="홈" />

    <fragment
        android:id="@+id/recommendFragment"
        android:name="com.example.plog.ui.recommend.RecommendFragment"
        android:label="추천">
        <action
            android:id="@+id/action_recommend_to_detail"
            app:destination="@id/placeDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/localFragment"
        android:name="com.example.plog.ui.local.LocalFragment"
        android:label="로컬" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.plog.ui.search.SearchFragment"
        android:label="검색" />

    <fragment
        android:id="@+id/myFragment"
        android:name="com.example.plog.ui.my.MyFragment"
        android:label="My" />

    <fragment
        android:id="@+id/placeDetailFragment"
        android:name="com.example.plog.ui.recommend.PlaceDetailFragment"
        android:label="장소 상세">
        <argument
            android:name="contentId"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="contentTypeId"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="title"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="address"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="imageUrl"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="category"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="distance"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="latitude"
            app:argType="float"
            android:defaultValue="0" />
        <argument
            android:name="longitude"
            app:argType="float"
            android:defaultValue="0" />
    </fragment>

</navigation>