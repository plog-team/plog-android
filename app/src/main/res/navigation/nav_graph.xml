<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.plog.ui.home.HomeFragment"
        android:label="홈">
        <action
            android:id="@+id/action_home_to_aiChatEntry"
            app:destination="@id/aiChatEntryFragment" />
    </fragment>
    <fragment
        android:id="@+id/recommendFragment"
        android:name="com.example.plog.ui.recommend.RecommendFragment"
        android:label="추천" />
    <fragment
        android:id="@+id/localFragment"
        android:name="com.example.plog.ui.local.LocalFragment"
        android:label="로컬" />
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.plog.ui.search.SearchFragment"
        android:label="검색" />
    <fragment
        android:id="@+id/myFragment"
        android:name="com.example.plog.ui.my.MyFragment"
        android:label="My" />

    <!-- AI 챗봇 -->
    <fragment
        android:id="@+id/aiChatEntryFragment"
        android:name="com.example.plog.ui.aichat.AiChatEntryFragment"
        android:label="AI 챗봇">
        <action
            android:id="@+id/action_aiChatEntry_to_aiChatOption"
            app:destination="@id/aiChatOptionFragment" />
    </fragment>
    <fragment
        android:id="@+id/aiChatOptionFragment"
        android:name="com.example.plog.ui.aichat.AiChatOptionFragment"
        android:label="대화 시작">
        <action
            android:id="@+id/action_aiChatOption_to_aiChat"
            app:destination="@id/aiChatFragment" />
        <action
            android:id="@+id/action_aiChatOption_to_diarySelect"
            app:destination="@id/diarySelectFragment" />
    </fragment>
    <fragment
        android:id="@+id/diarySelectFragment"
        android:name="com.example.plog.ui.aichat.DiarySelectFragment"
        android:label="일기 선택">
        <action
            android:id="@+id/action_diarySelect_to_aiChat"
            app:destination="@id/aiChatFragment" />
    </fragment>
    <fragment
        android:id="@+id/aiChatFragment"
        android:name="com.example.plog.ui.aichat.AiChatFragment"
        android:label="AI 대화" />
</navigation>