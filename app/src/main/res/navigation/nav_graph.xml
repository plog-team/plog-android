<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">
<!--    테스트후에 @id/homeFragment로 변경-->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.plog.ui.home.HomeFragment"
        android:label="홈">
        <action
            android:id="@+id/action_homeFragment_to_diaryEditFragment"
            app:destination="@id/diaryEditFragment" />
        <action
            android:id="@+id/action_homeFragment_to_diaryDetailFragment"
            app:destination="@id/diaryDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/diaryEditFragment"
        android:name="com.example.plog.ui.diary.DiaryEditFragment"
        android:label="일기 작성" />
    <fragment
        android:id="@+id/diaryDetailFragment"
        android:name="com.example.plog.ui.diary.DiaryDetailFragment"
        android:label="일기 열람">
        <action
            android:id="@+id/action_diaryDetailFragment_to_diaryEditFragment"
            app:destination="@id/diaryEditFragment" />
    </fragment>
    <fragment
        android:id="@+id/recommendFragment"
        android:name="com.example.plog.ui.placeholder.PlaceholderFragment"
        android:label="추천" />
    <fragment
        android:id="@+id/localFragment"
        android:name="com.example.plog.ui.placeholder.PlaceholderFragment"
        android:label="로컬" />
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.plog.search.SearchFragment"
        android:label="검색" />
    <fragment
        android:id="@+id/myFragment"
        android:name="com.example.plog.ui.placeholder.PlaceholderFragment"
        android:label="My" />

    <fragment
        android:id="@+id/autoFillFragment"
        android:name="com.example.plog.autofill.AutoFillFragment"
        android:label="자동입력" />
    <fragment
        android:id="@+id/aiGuideEntryFragment"
        android:name="com.example.plog.ui.aiguide.AiGuideEntryFragment"
        android:label="AI 가이드">
        <action
            android:id="@+id/action_entry_to_session"
            app:destination="@id/aiGuideSessionFragment" />
        <action
            android:id="@+id/action_entry_to_chat"
            app:destination="@id/aiGuideChatFragment" />
    </fragment>
    <fragment
        android:id="@+id/aiGuideChatFragment"
        android:name="com.example.plog.ui.aiguide.AiGuideChatFragment"
        android:label="대화 가이드">
        <argument
            android:name="sessionId"
            app:argType="long"
            android:defaultValue="-1L" />
        <argument
            android:name="firstMessage"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>
    <fragment
        android:id="@+id/aiGuideSessionFragment"
        android:name="com.example.plog.ui.aiguide.AiGuideSessionFragment"
        android:label="가이드 질문">
        <argument
            android:name="sessionId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>
    <fragment
        android:id="@+id/aiGuideDraftFragment"
        android:name="com.example.plog.ui.aiguide.AiGuideDraftFragment"
        android:label="AI 초안">
        <argument
            android:name="sessionId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>
</navigation>
