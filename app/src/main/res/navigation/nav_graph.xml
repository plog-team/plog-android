<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.plog.ui.home.HomeFragment"
        android:label="홈">
        <action
            android:id="@+id/action_homeFragment_to_diaryEditFragment"
            app:destination="@id/diaryEditFragment" />
        <action
            android:id="@+id/action_homeFragment_to_diaryDetailFragment"
            app:destination="@id/diaryDetailFragment" />
        <action
            android:id="@+id/action_home_to_place_report"
            app:destination="@id/placeReportFragment" />
        <action
            android:id="@+id/action_home_to_emotion_report"
            app:destination="@id/emotionReportFragment" />
        <action
            android:id="@+id/action_home_to_analysis"
            app:destination="@id/analysisFragment" />
        <action
            android:id="@+id/action_homeFragment_to_calendarFragment"
            app:destination="@id/calendarFragment" />
    </fragment>

    <fragment
        android:id="@+id/diaryEditFragment"
        android:name="com.example.plog.ui.diary.DiaryEditFragment"
        android:label="일기 작성">
        <action
            android:id="@+id/action_diaryEditFragment_to_aiGuideEntryFragment"
            app:destination="@id/aiGuideEntryFragment" />
    </fragment>

    <fragment
        android:id="@+id/diaryDetailFragment"
        android:name="com.example.plog.ui.diary.DiaryDetailFragment"
        android:label="일기 열람">
        <action
            android:id="@+id/action_diaryDetailFragment_to_diaryEditFragment"
            app:destination="@id/diaryEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/recommendFragment"
        android:name="com.example.plog.ui.recommend.RecommendFragment"
        android:label="추천">
        <action
            android:id="@+id/action_recommend_to_detail"
            app:destination="@id/placeDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/placeDetailFragment"
        android:name="com.example.plog.ui.recommend.PlaceDetailFragment"
        android:label="장소 상세">
        <argument android:name="contentId"     app:argType="string" android:defaultValue="" />
        <argument android:name="contentTypeId" app:argType="string" android:defaultValue="" />
        <argument android:name="title"         app:argType="string" android:defaultValue="" />
        <argument android:name="address"       app:argType="string" android:defaultValue="" />
        <argument android:name="imageUrl"      app:argType="string" android:defaultValue="" />
        <argument android:name="category"      app:argType="string" android:defaultValue="" />
        <argument android:name="distance"      app:argType="string" android:defaultValue="" />
        <argument android:name="latitude"      app:argType="float"  android:defaultValue="0" />
        <argument android:name="longitude"     app:argType="float"  android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/localFragment"
        android:name="com.example.plog.ui.placeholder.PlaceholderFragment"
        android:label="로컬" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.plog.search.SearchFragment"
        android:label="검색" />

    <fragment
        android:id="@+id/myFragment"
        android:name="com.example.plog.ui.placeholder.PlaceholderFragment"
        android:label="My" />

    <fragment
        android:id="@+id/autoFillFragment"
        android:name="com.example.plog.autofill.AutoFillFragment"
        android:label="자동입력" />

    <fragment
        android:id="@+id/aiGuideEntryFragment"
        android:name="com.example.plog.ui.aiguide.AiGuideEntryFragment"
        android:label="AI 가이드">
        <action android:id="@+id/action_entry_to_session" app:destination="@id/aiGuideSessionFragment" />
        <action android:id="@+id/action_entry_to_chat"    app:destination="@id/aiGuideChatFragment" />
    </fragment>

    <fragment
        android:id="@+id/aiGuideChatFragment"
        android:name="com.example.plog.ui.aiguide.AiGuideChatFragment"
        android:label="대화 가이드">
        <argument android:name="sessionId"    app:argType="long"   android:defaultValue="-1L" />
        <argument android:name="firstMessage" app:argType="string" app:nullable="true" android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/aiGuideSessionFragment"
        android:name="com.example.plog.ui.aiguide.AiGuideSessionFragment"
        android:label="가이드 질문">
        <argument android:name="sessionId" app:argType="long" android:defaultValue="-1L" />
    </fragment>

    <fragment
        android:id="@+id/aiGuideDraftFragment"
        android:name="com.example.plog.ui.aiguide.AiGuideDraftFragment"
        android:label="AI 초안">
        <argument android:name="sessionId" app:argType="long" android:defaultValue="-1L" />
    </fragment>

    <fragment
        android:id="@+id/placeReportFragment"
        android:name="com.example.plog.ui.report.PlaceReportFragment"
        android:label="월간 장소 분석 리포트">
        <action
            android:id="@+id/action_placeReport_to_analysisFragment"
            app:destination="@id/analysisFragment" />
    </fragment>

    <fragment
        android:id="@+id/emotionReportFragment"
        android:name="com.example.plog.ui.report.EmotionReportFragment"
        android:label="주간 감정 분석 리포트" />

    <!-- photo-metadata-analyzer -->
    <fragment
        android:id="@+id/photoPickerFragment"
        android:name="com.example.plog.ui.photo.PhotoPickerFragment"
        android:label="사진 선택">
        <action
            android:id="@+id/action_photoPickerFragment_to_analysisFragment"
            app:destination="@id/analysisFragment" />
    </fragment>

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.example.plog.ui.map.MapFragment"
        android:label="지도" />

    <fragment
        android:id="@+id/analysisFragment"
        android:name="com.example.plog.ui.analysis.AnalysisFragment"
        android:label="월간 리포트" />

    <fragment
        android:id="@+id/calendarFragment"
        android:name="com.example.plog.ui.calendar.CalendarFragment"
        android:label="CalendarFragment"
        tools:layout="@layout/fragment_calendar" />

</navigation>
