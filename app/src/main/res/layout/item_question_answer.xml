<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:lineSpacingExtra="3dp"
            android:textColor="#212121" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="후보 답변 (탭하면 자동 입력)"
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- [Day 8.18] MaterialCardView 답변 카드 3장 — 채택 시 stroke 강조 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAnswer1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp"
            app:strokeColor="#6750A4"
            app:cardBackgroundColor="#FAFAFA"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <TextView
                android:id="@+id/tvAnswer1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="4"
                android:ellipsize="end"
                android:textColor="#222222" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAnswer2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp"
            app:strokeColor="#6750A4"
            app:cardBackgroundColor="#FAFAFA"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <TextView
                android:id="@+id/tvAnswer2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="4"
                android:ellipsize="end"
                android:textColor="#222222" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAnswer3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp"
            app:strokeColor="#6750A4"
            app:cardBackgroundColor="#FAFAFA"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <TextView
                android:id="@+id/tvAnswer3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="4"
                android:ellipsize="end"
                android:textColor="#222222" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="직접 입력 (선택)"
            android:textSize="11sp"
            android:textColor="#888888" />

        <EditText
            android:id="@+id/etAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="원하면 직접 적어 주세요"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2"
            android:maxLines="5"
            android:gravity="top"
            android:padding="10dp"
            android:background="#F5F5F5"
            android:textSize="14sp"
            android:autofillHints="" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
