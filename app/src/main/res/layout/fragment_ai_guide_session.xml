<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 헤더: 진행 표시 + 페이지 N/M -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="가이드 질문에 답해 주세요"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 1"
            android:textSize="14sp"
            android:textColor="#6750A4" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="후보 중에서 가까운 답을 탭하거나, 직접 적어 주세요. 모든 질문에 답하지 않아도 됩니다."
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp" />

    <!-- Vision 칩 -->
    <TextView
        android:id="@+id/tvVisionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI가 분석한 사진 컨텍스트"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#888888"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cgVision"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:chipSpacingHorizontal="6dp"
        app:singleLine="false" />

    <!-- 좌우 스와이프 + 한 페이지 1질문 ViewPager2 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vpQuestions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- 하단 좌우 네비게이션 + 초안 만들기 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="◀ 이전"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="다음 ▶"
            style="?android:attr/buttonBarButtonStyle" />
    </LinearLayout>

    <Button
        android:id="@+id/btnDraft"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="초안 만들기" />

</LinearLayout>
