<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="96dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnClose"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="×"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/tvMode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="일기 작성"
                    android:textColor="@color/gray_400"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/btnBookmark"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="☆"
                    android:textColor="@color/gray_700"
                    android:textSize="23sp" />

                <TextView
                    android:id="@+id/btnSave"
                    android:layout_width="52dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_black_round"
                    android:gravity="center"
                    android:text="저장"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_700" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="날짜"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etWeather"
                    android:layout_width="96dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:gravity="end|center_vertical"
                    android:hint="날씨"
                    android:inputType="text"
                    android:maxLines="1"
                    android:text="맑음"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/gray_400"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/photoPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_diary_panel"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvPhotoCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/10(사진 개수)"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp" />

                <FrameLayout
                    android:id="@+id/photoPickerArea"
                    android:layout_width="match_parent"
                    android:layout_height="164dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_photo_placeholder"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/ivRepresentativePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/emptyPhotoState"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+"
                            android:textColor="@color/text_primary"
                            android:textSize="30sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="이미지 추가하기"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </FrameLayout>

                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:color/transparent"
                    android:hint="공란처리"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/gray_400"
                    android:textSize="12sp" />

                <HorizontalScrollView
                    android:id="@+id/photoScroll"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginTop="6dp"
                    android:fillViewport="false"
                    android:overScrollMode="never"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/photoStrip"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_diary_field"
                android:hint="제목을 입력하세요"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/gray_400"
                android:textSize="13sp" />

            <com.example.plog.ui.diary.LinedEditText
                android:id="@+id/etBody"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_diary_field"
                android:gravity="top|start"
                android:hint="내용을 입력하세요"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="10"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/gray_400"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/aiMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="72dp"
        android:layout_marginBottom="88dp"
        android:background="@drawable/bg_ai_menu"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btnAiQuestion"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:text="AI 질문 생성"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnAiDraft"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:text="AI 초안 생성"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnAi"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="72dp"
        android:background="@drawable/bg_purple_circle"
        android:elevation="8dp"
        android:gravity="center"
        android:text="+"
        android:textColor="@color/white"
        android:textSize="32sp" />

</FrameLayout>
