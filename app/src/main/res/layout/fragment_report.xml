<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 닫기 버튼 툴바 (스크롤 안 됨) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="#212121"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- 스크롤 컨텐츠 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일기로 되돌아보는"
                android:textSize="15sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사용자 님의 이번 달 활동"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <!-- ══════════════ STATE: LOADING ══════════════ -->
            <LinearLayout
                android:id="@+id/layoutLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="48dp"
                android:paddingBottom="48dp"
                android:visibility="visible">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminate="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="일기를 분석하는 중이에요..."
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="잠시만 기다려 주세요"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- ══════════════ STATE: INTERRUPTED ══════════════ -->
            <LinearLayout
                android:id="@+id/layoutInterrupt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="분석 중 확인이 필요해요"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#212121" />

                        <TextView
                            android:id="@+id/tvInterruptDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginTop="8dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvInterruptQuestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#212121"
                            android:lineSpacingExtra="2dp"
                            android:layout_marginBottom="16dp" />

                        <!-- 선택지 버튼들이 동적으로 추가됨 -->
                        <LinearLayout
                            android:id="@+id/layoutOptions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <ProgressBar
                            android:id="@+id/progressInterrupt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:indeterminate="true"
                            android:visibility="gone" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ══════════════ 장소 리포트 아코디언 ══════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPlace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 초록 헤더 -->
                    <LinearLayout
                        android:id="@+id/headerPlace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="#4CAF50"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="장소 리포트"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvPlaceChevron"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="∨"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF" />

                    </LinearLayout>

                    <!-- 장소 리포트 컨텐츠 (기본: 펼쳐짐) -->
                    <LinearLayout
                        android:id="@+id/contentPlace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvPlacePeriod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="12dp" />

                        <!-- 가장 자주 방문한 장소의 대표 사진 -->
                        <ImageView
                            android:id="@+id/ivTopPlacePhoto"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:scaleType="centerCrop"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone" />

                        <!-- AI 생성 장소 분석 텍스트 -->
                        <TextView
                            android:id="@+id/tvPlaceContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#212121"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginBottom="12dp" />

                        <!-- 장소 목록 -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvPlaces"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════ 감정 리포트 아코디언 ══════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEmotion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 보라 헤더 -->
                    <LinearLayout
                        android:id="@+id/headerEmotion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="#9C27B0"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="감정 리포트"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvEmotionChevron"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="∨"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF" />

                    </LinearLayout>

                    <!-- 감정 리포트 컨텐츠 (기본: 펼쳐짐) -->
                    <LinearLayout
                        android:id="@+id/contentEmotion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvEmotionPeriod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="12dp" />

                        <!-- AI 생성 감정 분석 텍스트 -->
                        <TextView
                            android:id="@+id/tvEmotionContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#212121"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginBottom="12dp" />

                        <!-- 감정 막대 (동적으로 추가됨) -->
                        <LinearLayout
                            android:id="@+id/layoutEmotionBars"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="8dp" />

                        <!-- 요일별 감정 (동적으로 추가됨) -->
                        <LinearLayout
                            android:id="@+id/layoutEmotionByDay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════ 피드백 (DONE 상태에서만 표시) ══════════════ -->
            <LinearLayout
                android:id="@+id/layoutFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="리포트가 도움이 됐나요?"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />

                <RatingBar
                    android:id="@+id/ratingBar"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1"
                    android:rating="0"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/etFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top"
                    android:background="#F5F5F5"
                    android:padding="8dp"
                    android:hint="한 마디 남겨 주세요 (선택)"
                    android:inputType="textMultiLine"
                    android:layout_marginTop="12dp" />

                <Button
                    android:id="@+id/btnFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="피드백 보내기"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
