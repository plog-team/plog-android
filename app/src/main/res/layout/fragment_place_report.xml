<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="#212121"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일기로 되돌아보는"
                android:textSize="15sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사용자 님의 이번 달 장소"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <!-- STATE: LOADING -->
            <LinearLayout
                android:id="@+id/layoutLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="48dp"
                android:paddingBottom="48dp"
                android:visibility="visible">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminate="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="방문 장소를 분석하는 중이에요..."
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="잠시만 기다려 주세요"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- STATE: INTERRUPTED -->
            <LinearLayout
                android:id="@+id/layoutInterrupt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="분석 중 확인이 필요해요"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#212121" />

                        <TextView
                            android:id="@+id/tvInterruptDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginTop="8dp" />

                        <!-- 일기 열람 토글 -->
                        <TextView
                            android:id="@+id/tvDiaryToggle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="일기 열람 ▼"
                            android:textSize="13sp"
                            android:textColor="#9C63F5"
                            android:layout_marginTop="8dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <!-- 일기 본문 (접힘) -->
                        <LinearLayout
                            android:id="@+id/layoutDiaryContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#E8E0F8"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp" />

                            <TextView
                                android:id="@+id/tvDiaryBody"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="#424242"
                                android:lineSpacingExtra="4dp"
                                android:background="#F7F2FE"
                                android:padding="12dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvInterruptQuestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#212121"
                            android:lineSpacingExtra="2dp"
                            android:layout_marginBottom="16dp" />

                        <!-- 선택지 버튼 목록 -->
                        <LinearLayout
                            android:id="@+id/layoutOptions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <!-- 자유 입력 (options 없을 때 표시) -->
                        <LinearLayout
                            android:id="@+id/layoutFreeAnswer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <EditText
                                android:id="@+id/etFreeAnswer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="직접 입력해 주세요"
                                android:inputType="text"
                                android:background="#F5F5F5"
                                android:padding="12dp"
                                android:layout_marginBottom="8dp" />

                            <Button
                                android:id="@+id/btnSubmitFreeAnswer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="확인"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#9C63F5"
                                android:layout_marginBottom="4dp" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressInterrupt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:indeterminate="true"
                            android:visibility="gone" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- 장소 리포트 아코디언 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPlace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerPlace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="#4CAF50"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="이번 달 방문 장소"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvPlaceChevron"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="∨"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentPlace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvPlacePeriod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="12dp" />

                        <ImageView
                            android:id="@+id/ivTopPlacePhoto"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:scaleType="centerCrop"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvPlaceContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#212121"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:id="@+id/layoutPlaceBars"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="4dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 피드백 -->
            <LinearLayout
                android:id="@+id/layoutFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 폼 상태 -->
                <LinearLayout
                    android:id="@+id/layoutFeedbackForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="16dp" />

                    <!--
                        TODO: 경로 분석 화면으로의 네비게이션을 연결해 주세요.
                        PlaceReportFragment에서 btnRouteAnalysis.setOnClickListener { ... } 로 처리하거나,
                        해당 Fragment/Activity로 navigate하는 로직을 추가하면 됩니다.
                    -->
                    <Button
                        android:id="@+id/btnRouteAnalysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="일기 사진으로 경로 분석하기"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#9C63F5"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="리포트가 도움이 됐나요?"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#212121" />

                    <!-- 별점: 1→연보라 → 5→진보라 그라데이션 -->
                    <LinearLayout
                        android:id="@+id/layoutStars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/star1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textSize="36sp"
                            android:paddingEnd="4dp"
                            android:textColor="#BDBDBD"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/star2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textSize="36sp"
                            android:paddingEnd="4dp"
                            android:textColor="#BDBDBD"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/star3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textSize="36sp"
                            android:paddingEnd="4dp"
                            android:textColor="#BDBDBD"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/star4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textSize="36sp"
                            android:paddingEnd="4dp"
                            android:textColor="#BDBDBD"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/star5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textSize="36sp"
                            android:textColor="#BDBDBD"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <EditText
                        android:id="@+id/etFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="3"
                        android:gravity="top"
                        android:background="#F5F5F5"
                        android:padding="8dp"
                        android:hint="한 마디 남겨 주세요 (선택)"
                        android:inputType="textMultiLine"
                        android:layout_marginTop="12dp" />

                    <Button
                        android:id="@+id/btnFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="피드백 보내기"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp" />

                </LinearLayout>

                <!-- 완료 상태 -->
                <LinearLayout
                    android:id="@+id/layoutFeedbackSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="32dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="44sp"
                        android:textColor="#9C63F5"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="피드백 감사해요!"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="다음 분석부터 AI가 이번 피드백을 반영해\n더 잘 맞는 리포트를 작성해 드릴게요."
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
