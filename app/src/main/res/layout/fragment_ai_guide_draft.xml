<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI 초안 검토"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="초안을 확인하고 마음에 들면 일기에 반영하세요."
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etDraft"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="10"
            android:gravity="top"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:inputType="textMultiLine|textCapSentences"
            android:textIsSelectable="true"
            android:autofillHints="" />

        <TextView
            android:id="@+id/tvCharCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:gravity="end" />

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="일기에 반영" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#E0E0E0" />

        <!-- [Day 8.11] 메모리 섹션 — 제목 옆 Switch로 펼침 토글 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📝 내 일기 작성 취향을 AI에 학습시키기"
                android:textStyle="bold"
                android:textSize="15sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swMemory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/memoryContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="일기 초안 작성에 있어서 앞으로 반영하면 좋을 사항이 있다면 적어주세요!"
                android:textSize="12sp"
                android:textColor="#666666" />

            <EditText
                android:id="@+id/etFeedbackComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="예: 끝말은 다체로 통일해주세요. 음식 묘사는 간단히. 비유 표현은 줄여주세요."
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:gravity="top"
                android:padding="8dp"
                android:background="#F5F5F5"
                android:autofillHints="" />

            <Button
                android:id="@+id/btnSubmitFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="다음 일기에 반영하기" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:indeterminate="true"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
